{
  "name": "cold-flu-research-base",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-led cold and flu research base and unpublished research preview",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:content && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "report:import": "node scripts/generate-import-report.mjs"
  },
  "dependencies": {
    "next": "^15.5.9",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.18.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
