{
  "name": "cold-flu-research-base",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "description": "Evidence-led cold and flu research base and unpublished research preview",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:content && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.*",
    "test:http": "node --import tsx --test tests/http-auth.test.ts",
    "validate:content": "node scripts/validate-content.mjs",
    "report:import": "node scripts/generate-import-report.mjs",
    "check:media-links": "node scripts/check-media-links.mjs",
    "check:internal-links": "node scripts/check-internal-links.mjs",
    "check:spelling": "cspell --no-progress --show-suggestions",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "^15.5.9",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.10.0",
    "@emnapi/wasi-threads": "^1.2.1",
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cspell": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "tsx": "^4.20.5",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
