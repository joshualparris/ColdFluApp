{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coldfluresearch.example/schemas/module.schema.json",
  "title": "Cold & Flu Research Module",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "id", "slug", "title", "description", "category",
    "status", "audience", "jurisdictions", "locale", "summary", "safety",
    "claims", "practicalGuidance", "myths", "jurisdictionNotes",
    "relatedModules", "sourceIds", "review"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/id" },
    "slug": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1, "maxLength": 240 },
    "category": {
      "enum": ["symptom", "intervention", "population", "prevention", "triage"]
    },
    "status": {
      "enum": ["proposed", "researching", "draft", "evidence_review", "clinical_review", "editorial_review", "published", "archived"]
    },
    "audience": { "type": "string", "minLength": 1 },
    "jurisdictions": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/jurisdiction" }
    },
    "locale": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "summary": { "type": "string", "minLength": 1 },
    "safety": {
      "type": "object", "additionalProperties": false,
      "required": ["emergencySummary", "redFlags", "vulnerableGroups"],
      "properties": {
        "emergencySummary": { "type": "string", "minLength": 1 },
        "redFlags": { "type": "array", "items": { "$ref": "#/$defs/safetyItem" } },
        "vulnerableGroups": { "type": "array", "items": { "$ref": "#/$defs/safetyItem" } }
      }
    },
    "claims": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/$defs/claim" }
    },
    "practicalGuidance": {
      "type": "array",
      "items": { "$ref": "#/$defs/guidance" }
    },
    "myths": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["myth", "correction", "sourceIds"],
        "properties": {
          "myth": { "type": "string", "minLength": 1 },
          "correction": { "type": "string", "minLength": 1 },
          "sourceIds": { "$ref": "#/$defs/sourceIds" }
        }
      }
    },
    "jurisdictionNotes": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["jurisdiction", "text", "effectiveAt", "sourceIds"],
        "properties": {
          "jurisdiction": { "$ref": "#/$defs/jurisdiction" },
          "text": { "type": "string", "minLength": 1 },
          "effectiveAt": { "$ref": "#/$defs/date" },
          "sourceIds": { "$ref": "#/$defs/sourceIds" }
        }
      }
    },
    "relatedModules": {
      "type": "array", "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "sourceIds": { "$ref": "#/$defs/sourceIds" },
    "review": {
      "type": "object", "additionalProperties": false,
      "required": ["researchOwner", "evidenceReviewer", "clinicalReviewer", "editorialReviewer", "lastEvidenceSearch", "lastClinicallyReviewed", "nextReviewDue", "changeSummary"],
      "properties": {
        "researchOwner": { "$ref": "#/$defs/nullableString" },
        "evidenceReviewer": { "$ref": "#/$defs/nullableString" },
        "clinicalReviewer": { "$ref": "#/$defs/nullableString" },
        "editorialReviewer": { "$ref": "#/$defs/nullableString" },
        "lastEvidenceSearch": { "$ref": "#/$defs/nullableDate" },
        "lastClinicallyReviewed": { "$ref": "#/$defs/nullableDate" },
        "nextReviewDue": { "$ref": "#/$defs/nullableDate" },
        "changeSummary": { "$ref": "#/$defs/nullableString" }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "jurisdiction": { "type": "string", "pattern": "^(GLOBAL|[A-Z]{2})$" },
    "date": { "type": "string", "format": "date" },
    "nullableDate": { "anyOf": [{ "$ref": "#/$defs/date" }, { "type": "null" }] },
    "nullableString": { "type": ["string", "null"] },
    "sourceIds": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "safetyItem": {
      "type": "object", "additionalProperties": false,
      "required": ["text", "action", "sourceIds"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "action": { "enum": ["call_emergency", "urgent_assessment", "medical_advice", "pharmacist_advice"] },
        "sourceIds": { "$ref": "#/$defs/sourceIds" }
      }
    },
    "claim": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "statement", "outcome", "population", "intervention", "comparison", "evidence", "sourceIds", "caveats", "jurisdictions", "reviewedAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "statement": { "type": "string", "minLength": 1 },
        "outcome": {
          "enum": ["symptom_comfort", "pain", "fever", "hydration", "illness_duration", "complications", "transmission", "harms", "care_escalation"]
        },
        "population": { "type": "string", "minLength": 1 },
        "intervention": {
          "type": "object", "additionalProperties": false,
          "required": ["name", "formulation", "regimenStudied"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "formulation": { "$ref": "#/$defs/nullableString" },
            "regimenStudied": { "$ref": "#/$defs/nullableString" }
          }
        },
        "comparison": { "$ref": "#/$defs/nullableString" },
        "evidence": {
          "type": "object", "additionalProperties": false,
          "required": ["certainty", "direction", "effectSummary", "rationale"],
          "properties": {
            "certainty": { "enum": ["high", "moderate", "low", "very_low", "insufficient"] },
            "direction": { "enum": ["benefit", "no_clear_effect", "harm", "mixed"] },
            "effectSummary": { "$ref": "#/$defs/nullableString" },
            "rationale": { "type": "string", "minLength": 1 }
          }
        },
        "sourceIds": { "$ref": "#/$defs/sourceIds" },
        "caveats": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "jurisdictions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/jurisdiction" } },
        "reviewedAt": { "$ref": "#/$defs/nullableDate" }
      }
    },
    "guidance": {
      "type": "object", "additionalProperties": false,
      "required": ["title", "text", "kind", "professionalAdviceRequired", "sourceIds"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["comfort", "medicine", "avoid", "monitor", "care_pathway"] },
        "professionalAdviceRequired": { "type": "boolean" },
        "sourceIds": { "$ref": "#/$defs/sourceIds" }
      }
    }
  }
}
